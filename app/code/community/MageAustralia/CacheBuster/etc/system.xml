<config>
    <sections>
        <mageaustralia_cachebuster translate="label" module="mageaustralia_cachebuster">
            <label>Cache Buster</label>
            <tab>advanced</tab>
            <sort_order>1500</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>1</show_in_website>
            <show_in_store>1</show_in_store>
            <groups>
                <general translate="label">
                    <label>General</label>
                    <sort_order>10</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Enabled</label>
                            <comment><![CDATA[When enabled, asset URLs in the rendered HTML get a <code>?v=&lt;filemtime&gt;</code> query string appended so browsers and CDNs refetch them when the underlying file changes. No nginx/apache rewrite rules required.]]></comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default><show_in_website>1</show_in_website><show_in_store>1</show_in_store>
                        </enabled>
                        <areas translate="label">
                            <label>Areas</label>
                            <comment>Which areas to bust. `frontend` only is the safe default; `adminhtml` is rarely worth the post-processing overhead.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>mageaustralia_cachebuster/system_areas</source_model>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default><show_in_website>1</show_in_website><show_in_store>1</show_in_store>
                        </areas>
                    </fields>
                </general>
                <paths translate="label">
                    <label>Paths to Bust</label>
                    <comment>Which URL path prefixes the post-processor will version-stamp. Turn one off if it conflicts with an upstream CDN that already versions that path.</comment>
                    <sort_order>20</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <bust_skin translate="label"><label>Bust /skin/ URLs</label>
                            <frontend_type>select</frontend_type><source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default><show_in_website>1</show_in_website><show_in_store>1</show_in_store>
                        </bust_skin>
                        <bust_js translate="label"><label>Bust /js/ URLs</label>
                            <frontend_type>select</frontend_type><source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default><show_in_website>1</show_in_website><show_in_store>1</show_in_store>
                        </bust_js>
                        <bust_media translate="label">
                            <label>Bust /media/ URLs</label>
                            <comment>Media files are usually content-addressed by name already (product image filenames change with the image). Leave on if you want CMS-uploaded images to also get versioned.</comment>
                            <frontend_type>select</frontend_type><source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default><show_in_website>1</show_in_website><show_in_store>1</show_in_store>
                        </bust_media>
                    </fields>
                </paths>
            </groups>
        </mageaustralia_cachebuster>
    </sections>
</config>
